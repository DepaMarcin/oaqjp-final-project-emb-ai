from flask import Flask, render_template, request
from EmotionDetection import emotion_detector

app = Flask(__name__)

@app.route("/emotionDetector")
def emotion_analyzer():
    """
    Trasa odbierająca tekst z front-endu strony internetowej,
    przesyłająca go do analizatora emocji i zwracająca sformatowany tekst.
    """
    # Pobieramy tekst wysłany przez skrypt JavaScript ze strony www
    text_to_analyze = request.args.get('textToAnalyze')
    
    # Przekazujemy tekst do naszego pakietu AI
    response = emotion_detector(text_to_analyze)
    
    # Wyciągamy poszczególne wyniki ze słownika
    anger = response['anger']
    disgust = response['disgust']
    fear = response['fear']
    joy = response['joy']
    sadness = response['sadness']
    dominant = response['dominant_emotion']
    
    # Budujemy string wyjściowy w 100% zgodny z wymaganiami klienta
    output_text = (
        f"For the given statement, the system response is 'anger': {anger}, "
        f"'disgust': {disgust}, 'fear': {fear}, 'joy': {joy} and 'sadness': {sadness}. "
        f"The dominant emotion is {dominant}."
    )
    return output_text

@app.route("/")
def render_index_page():
    """
    Główna trasa serwująca stronę startową aplikacji.
    """
    return render_template('index.html')

if __name__ == "__main__":
    # Uruchamiamy aplikację na porcie 5000 zgodnie z instrukcją
    app.run(host="0.0.0.0", port=5000)